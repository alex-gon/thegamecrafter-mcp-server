{
  "name": "@alex-gon/tgc-mcp-server",
  "version": "0.2.0",
  "mcpName": "io.github.alex-gon/thegamecrafter",
  "description": "MCP server for The Game Crafter API — design, manage, and price tabletop games through AI",
  "main": "dist/index.js",
  "bin": {
    "tgc-mcp-server": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".env.example",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx --env-file=.env src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run test && npm run build"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "thegamecrafter",
    "boardgames",
    "tabletop"
  ],
  "author": "Alex Stevens <alex-gon@users.noreply.github.com> (https://github.com/alex-gon)",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alex-gon/thegamecrafter-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/alex-gon/thegamecrafter-mcp-server/issues"
  },
  "homepage": "https://github.com/alex-gon/thegamecrafter-mcp-server#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "image-size": "^2.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
