{
  "name": "tgc-mcp-server",
  "version": "0.1.0",
  "description": "MCP server connecting Claude to The Game Crafter API for designing, managing, and pricing tabletop games",
  "main": "dist/index.js",
  "bin": {
    "tgc-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".env.example",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx --env-file=.env src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "thegamecrafter",
    "boardgames",
    "tabletop"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alex-gon/thegamecrafter-mcp-server.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "image-size": "^2.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
