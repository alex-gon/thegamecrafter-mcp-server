# The Game Crafter MCP Server — Environment Variables
# Copy this file to .env and fill in your credentials.
# Get your API key at https://www.thegamecrafter.com/account/apikeys

TGC_API_KEY_ID=your-api-key-id-here
TGC_USERNAME=your-tgc-username
TGC_PASSWORD=your-tgc-password

# Optional: override the API base URL (defaults to production)
# TGC_API_BASE=https://www.thegamecrafter.com/api

# Optional: restrict file uploads to a specific directory (defaults to cwd)
# TGC_UPLOAD_BASE_DIR=/path/to/allowed/uploads
